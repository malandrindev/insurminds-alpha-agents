.env
.env.*
!.env.example
.venv/
venv/
__pycache__/
.ipynb_checkpoints/
*.pyc
.DS_Store
Thumbs.db

# Arquivos temporários de revisão local
git-info.txt
estrutura-local.txt
insurminds-review.zip

# Dados originais e processados
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep


# Notebooks de terceiros: registrar links em docs/referencias.md
notebooks/references/*.ipynb
!notebooks/references/.gitkeep

# Artefatos finais versionados de forma controlada
outputs/submission/*
!outputs/submission/.gitkeep
!outputs/submission/submission.csv

outputs/figures/*
!outputs/figures/.gitkeep
!outputs/figures/*.png

outputs/evidencias/*
!outputs/evidencias/.gitkeep
!outputs/evidencias/*.png
